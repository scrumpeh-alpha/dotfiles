{
    "custom/arch": {
        "format": "≤░μΘ",
        "tooltip": true,
        "tooltip-format": "btw"
    },


    "hyprland/workspaces": {
        "disable-scroll": true,
        "all-outputs": true,
        "warp-on-scroll": false,
        "format": "{name}",
        "format-icons": {
            "urgent": "ΎΒς",
            "active": "ΎΗΤ",
            "default": "ΎΕΣ"
        }
    },
    "idle_inhibitor": {
        "format": "{icon}",
        "format-icons": {
            "activated": "ΎΒχ",
            "deactivated": "ΎΒ░"
        }
    },
    "backlight": {
        // "device": "acpi_video1",
        // "format": "{percent}% {icon}",
        "format": "{icon}",
        "tooltip-format" : "Brightness {percent}% {icon}",
        "format-icons": ["ΌΟΞ", "ΌΠΥ", "ΌΠΣ", "ΌΠΠ", "ΌΠΟ", "ΌΠΞ", "ΌΠΛ", "ΌΠΙ", "ΌΟδ"]
    },
    "pulseaudio": {
        "format": "{icon}  {volume}%",
        "format-bluetooth": "{icon} {volume}% ΎΛΦ {format_source}",
        "format-bluetooth-muted": "≤░ζθ {icon}ΎΛΦ {format_source}",
        "format-muted": "≤░ζθ {format_source}",
        // "format-bluetooth-muted": "Ύγσ {icon}ΎΛΦ {format_source}",
        // "format-muted": "Ύγσ {format_source}",
        "format-source": "ΎΕ░ {volume}%",
        "format-source-muted": "ΎΕ▒",
        "format-icons": {
            "headphone": "ΎΑξ",
            "hands-free": "ΎΨΡ",
            "headset": "ΎΨΡ",
            "phone": "ΎΓΧ",
            "portable": "ΎΓΧ",
            "car": "ΎΗ╣",
            "default": ["ΎΑο", "ΎΑπ", "ΎΑρ"]
        },
        "tooltip-format" : "{icon} {volume}%",
        "on-click": "pavucontrol"
    },
    "network": {
        // "format-wifi": "ΎΘτ   {essid} ({signalStrength}%)",
        "format-wifi": "ΎΘτ  ΎΑΝ",
        // "format-ethernet": "{ipaddr}/{cidr} ΎηΨ",
        "format-ethernet": "ΎηΨ N",
        // "tooltip-format": "{ifname} via {gwaddr} ΎηΨ",
        "tooltip-format": "{essid} - {gwaddr}",
        "format-linked": "{ifname} (No IP) ΎηΨ",
        "format-disconnected": "ΎΘτ  ΎΣπ",
        "on-click": "nm-connection-editor"
    },
    "cpu": {
        "format": "ΎΜδ  {usage}%",
        "tooltip": true
    },
    "memory": {
        "format": "ΎΔΚ  {}%",
	"tooltip": true
    },
    "temperature": {
        "interval": 10,
        "hwmon-path": "/sys/devices/platform/coretemp.0/hwmon/hwmon4/temp1_input",
        "critical-threshold": 100,
        "format-critical": "ΎΜΘ {temperatureC}",
        "format": "ΎΜΚ {temperatureC}┬░C"
    },
    "battery": {
        "states": {
            "warning": 30,
            "critical": 15
        },
        "format": "{icon}  {capacity}%",
        "format-critical": "<span color='#ee0055'>{icon} {capacity}%</span>",
        "format-full": "{icon}  {capacity}%",
        "format-charging": "ΎΩπ  {capacity}%",
        "format-plugged": "ΎΘο  {capacity}%",
        "format-alt": "{time}  {icon}",
        "format-icons": ["ΎΚΕ", "ΎΚΔ", "ΎΚΓ", "ΎΚΒ", "ΎΚΑ"]
    },
    "clock": {
        "format": "<span color='#eeeeee'>{:%I:%M %p}</span>",
        "locale": "en_US.UTF-8",
        "tooltip-format": "<big>{:%Y %B %d}</big>\n<tt><small>{calendar}</small></tt>",
        "format-alt": "<span color='#eeeeee'>{:%d/%m/%y}</span>"
    },
    "custom/lockscreen": {
        "format": "ΎΑμ",
        "tooltip-format" : "Lock screen",
        "on-click": "hyprlock",
    },
    // "group/controls": {
    //     "orientation": "inherit",
    //     "drawer": {
    //         "transition-duration": 500,
    //         "children-class": "childs",
    //         "transition-left-to-right": false
    //     },
    //     "modules": [
    //         "backlight",
    //         "pulseaudio",
    //         "network"
    //     ]
    // }
    "pulseaudio/slider": {
        "min": 5,
        "max": 100,
        "rotate": 0,
        "device": "pulseaudio",
        "scroll-step": 1,
      },
}
